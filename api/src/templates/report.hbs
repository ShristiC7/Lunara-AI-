<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: 'Helvetica', 'Arial', sans-serif; color: #333; line-height: 1.6; padding: 40px; }
        .header { border-bottom: 2px solid #6c5ce7; padding-bottom: 20px; margin-bottom: 30px; }
        .header h1 { color: #6c5ce7; margin: 0; }
        .header p { margin: 5px 0 0 0; color: #777; }
        
        .section { margin-bottom: 30px; }
        .section h2 { border-left: 4px solid #6c5ce7; padding-left: 10px; color: #2d3436; font-size: 20px; margin-bottom: 15px; }
        
        .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
        .stat-card { background: #f9f9f9; padding: 15px; border-radius: 8px; border: 1px solid #eee; }
        .stat-card .label { font-size: 12px; color: #888; text-transform: uppercase; }
        .stat-card .value { font-size: 24px; font-weight: bold; color: #6c5ce7; }
        
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { text-align: left; background: #f2f2f2; padding: 12px; border-bottom: 2px solid #ddd; }
        td { padding: 12px; border-bottom: 1px solid #eee; }
        
        .ai-insight { background: #f0f7ff; padding: 20px; border-radius: 10px; border: 1px solid #cce5ff; margin-top: 10px; }
        .ai-insight h3 { margin-top: 0; color: #004085; }
        
        .footer { margin-top: 50px; padding-top: 20px; border-top: 1px solid #eee; font-size: 10px; color: #aaa; text-align: center; }
        
        @media print {
            body { padding: 0; }
            .no-print { display: none; }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Lunara AI Health Report</h1>
        <p>Prepared for User ID: {{userId}} | Date: {{generatedAt}}</p>
    </div>

    <div class="section">
        <h2>Cycle Summary</h2>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="label">Avg Cycle Length</div>
                <div class="value">{{avgCycleLength}} days</div>
            </div>
            <div class="stat-card">
                <div class="label">Avg Period Length</div>
                <div class="value">{{avgPeriodLength}} days</div>
            </div>
        </div>
        
        <table>
            <thead>
                <tr>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Cycle Length</th>
                </tr>
            </thead>
            <tbody>
                {{#each cycles}}
                <tr>
                    <td>{{startDate}}</td>
                    <td>{{endDate}}</td>
                    <td>{{cycleLength}} days</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    <div class="section">
        <h2>Symptom Trends</h2>
        <p>Common symptoms reported during this period:</p>
        <ul>
            {{#each commonSymptoms}}
            <li>{{this}}</li>
            {{/each}}
        </ul>
    </div>

    <div class="section">
        <h2>AI Insights & Predictions</h2>
        <div class="ai-insight">
            <h3>Latest Analysis</h3>
            <p>{{latestInsight}}</p>
        </div>
        <p><strong>Next Predicted Period:</strong> {{nextPredictedDate}} (Confidence: {{confidence}})</p>
    </div>

    <div class="footer">
        <p>DISCLAIMER: This report is generated by AI for informational purposes only and does not constitute medical advice or diagnosis. Always consult with a healthcare professional for clinical concerns.</p>
        <p>&copy; 2026 Lunara AI. All rights reserved.</p>
    </div>
</body>
</html>
